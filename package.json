{
  "name": "canonic-backend",
  "version": "1.0.0",
  "description": "Backend API layer for Canonic vehicle management system",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec ts-node -r tsconfig-paths/register src/server.ts",
    "build": "tsc && tsc-alias",
    "vercel-build": "npm run build",
    "start": "node dist/server.js",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "typecheck": "tsc --noEmit",
    "init:schema": "ts-node -r tsconfig-paths/register src/scripts/init-schema-meta.ts",
    "test": "echo \"No automated tests currently configured. See README for manual verification steps.\" && exit 0"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "firebase-admin": "^14.2.0",
    "helmet": "^7.1.0",
    "zod": "^4.4.3"
  },
  "overrides": {
    "jose": "4.15.9"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.12",
    "@vercel/node": "^5.8.26",
    "eslint": "^9.25.0",
    "nodemon": "^3.1.0",
    "prettier": "^3.2.5",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.10",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.30.1"
  }
}
